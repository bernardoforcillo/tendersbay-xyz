# Dependencies
node_modules/

# Build outputs
dist/
build/
out/
.next/

# Keep the platform embed placeholder: Go //go:embed needs a tracked file in dist/.
# Re-include the dir (excluded by `dist/` above), ignore built contents, keep .gitkeep.
!apps/platform/dist/
apps/platform/dist/*
!apps/platform/dist/.gitkeep

# Turborepo
.turbo/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Environment
.env
.env.*
!.env.example

# Caches
coverage/
*.tsbuildinfo

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Claude Code (keep shared config, ignore personal overrides)
.claude/settings.local.json

# Superpowers scratch (design specs, implementation plans, SDD ledger) — not tracked
docs/superpowers/
.superpowers/
